# Copy this file to `.env` and fill in your key(s). `.env` is git-ignored.
# The app reads these on startup; without them it uses the offline template.

# Gemini (free tier: gemini-2.5-flash). Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional alternative LLM provider for the recommendation summary.
ANTHROPIC_API_KEY=
