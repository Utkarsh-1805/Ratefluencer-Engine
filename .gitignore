# Secrets — NEVER commit
.env
.env.*
!.env.example

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Streamlit
.streamlit/secrets.toml

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local outputs
*.log
*_out.txt
prep_out.txt
test_out.txt

# Data/model artifacts (regenerable). The ML layer is vendored at proj/ — we keep
# its source + the trained model (proj/models_store/true_impact.pkl) but NOT the
# data it builds (rebuilt by `python models/prepare_demo.py`).
data/*.db
data/*.db-*
data/vector/
data/synthetic/
data/seed/
proj/data/
proj/models_store/growth.pkl
proj/**/__pycache__/

# Frontend (React/Vite) — deps + build output are regenerable
web/node_modules/
web/dist/

# Documentation — only README.md is published
ARCHITECTURE.md
INTEGRATION.md
TEST_GUIDE.md
